{
  "name": "users-directory",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@react-navigation/native": "^7.3.4",
    "@react-navigation/native-stack": "^7.17.6",
    "@tanstack/react-query": "^5.101.1",
    "expo": "~56.0.12",
    "expo-constants": "~56.0.18",
    "expo-dev-client": "~56.0.20",
    "expo-image": "~56.0.11",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@config-plugins/detox": "^11.0.0",
    "@testing-library/react-native": "^14.0.1",
    "@types/detox": "^17.14.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.20.0",
    "@types/react": "~19.2.2",
    "babel-preset-expo": "^56.0.15",
    "detox": "^20.51.4",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^56.0.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "jest": "^29.7.0",
    "jest-expo": "^56.0.5",
    "msw": "^2.14.6",
    "prettier": "^3.8.5",
    "typescript": "~6.0.3"
  },
  "overrides": {
    "@config-plugins/detox": {
      "expo": "~56.0.12"
    }
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "typecheck:e2e": "tsc -p e2e/tsconfig.json --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "prebuild:ios": "expo prebuild -p ios",
    "prebuild:android": "expo prebuild -p android",
    "e2e:build": "detox build -c ios.sim.release",
    "e2e:test": "detox test -c ios.sim.release",
    "e2e:build:android": "detox build -c android.emu.release",
    "e2e:test:android": "detox test -c android.emu.release",
    "e2e:build:debug": "detox build -c ios.sim.debug",
    "e2e:test:debug": "detox test -c ios.sim.debug",
    "e2e:build:android:debug": "detox build -c android.emu.debug",
    "e2e:test:android:debug": "detox test -c android.emu.debug",
    "e2e:ios": "npm run prebuild:ios && npm run e2e:build && npm run e2e:test",
    "e2e:android": "npm run prebuild:android && npm run e2e:build:android && npm run e2e:test:android",
    "e2e:all": "npm run e2e:ios && npm run e2e:android"
  },
  "private": true
}
